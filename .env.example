# ─── Wingman Environment Configuration (template) ────────────────────

# Server
PORT=3000
NODE_ENV=development

# Public base URL of the deployment (used for OAuth redirect + links).
# In production set this to your Railway/custom domain, e.g. https://wingman.up.railway.app
PUBLIC_BASE_URL=http://localhost:3000

# Anthropic Claude API (LLM)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5

# Database (mount a Railway volume at /app/data in production)
DATABASE_PATH=./data/wingman.db

# Google OAuth (Gmail + Calendar)
# In production the redirect URI must be <PUBLIC_BASE_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# WhatsApp (whatsapp-web.js)
WHATSAPP_SESSION_PATH=./.wwebjs_auth
# Set to 1 to run API + dashboard only (no WhatsApp) — handy for screenshot demos
DISABLE_WHATSAPP=0

# Admin key protecting the browser-based WhatsApp pairing page (/admin/qr?key=...)
ADMIN_PASSWORD=change-me

# WhatsApp Business Cloud API (official Meta API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=wingman_verify
WHATSAPP_API_VERSION=v25.0

# Approved AUTHENTICATION template for OTP delivery.
OTP_TEMPLATE_NAME=wingman_login_otp
OTP_TEMPLATE_LANG=en_US
OTP_USE_TEMPLATE=1

# Approved UTILITY template for proactive briefings / wraps outside the 24h
# customer-service window. Create it with one body variable: {{1}}
PROACTIVE_TEMPLATE_NAME=
PROACTIVE_TEMPLATE_LANG=en_US
PROACTIVE_USE_TEMPLATE=1

# Weather (optional; falls back to a deterministic mock if unset)
WEATHER_API_KEY=
WEATHER_DEFAULT_CITY=Dubai

# Brevo transactional email API — used to SEND business-mailbox replies, because
# many hosts (e.g. Railway) block outbound SMTP. Reading still uses IMAP.
# Authenticate the sending domain in Brevo (SPF/DKIM) so mail isn't marked spam.
BREVO_API_KEY=

# Secret used to encrypt stored credentials at rest (webmail passwords, clock
# action secrets). Required for those features. Any long random string.
SECRET_KEY=

# In the Docker image the system Chromium is used by Puppeteer:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
